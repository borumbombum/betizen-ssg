---
title: "Boni"
description: "Einige der besten Boni auf empfohlenen Spielplattformen."
slugOverride: bonusse
hideNormalTitle: true
---


<div class="archive-title clearfix mb-0 pb-0" style="border-bottom: 0">
    <div class="row align-items-end">
        <div class="col-md-8">
            <h1 class="page-title mb-2 mb-md-0">
            Boni
            </h1>
            <div class="catalog-description mt-2 ml-1 mb-2">
                <p>Einige der besten Boni auf empfohlenen Spielplattformen.</p>
            </div>
        </div>
    </div>
</div>

<div class="row" id="listing">
    {%- for bonus in collections.bonuses -%}
        {% if bonus.data.lang == page.lang %}
        <div class="col-12 col-md-6 mb-4 pl-2 pr-2">
            <div class="card">
                <div class="p-2">
                    <div class="row">
                        <div class="col-3 d-flex align-items-center justify-content-center">
                            {% if bonus.data.image %}
                            <a href="{{ bonus.url }}">
                                <img decoding="async" width="100" height="100" src="{{ bonus.data.image }}" alt="{{ bonus.data.title }}" />
                            </a>
                            {% endif %}
                        </div>
                        <div class="col-9 card-body">
                            <a href="{{ bonus.url }}">
                                <h3 class="mt-0">{{ bonus.data.title }}</h3>
                            </a>
                            <div class="mt-3 d-flex justify-content-between align-items-center gap-2 flex-wrap">
                                <a href="{{ bonus.data.bonus.link if bonus.data.bonus.link else languages[page.lang].promo.url }}" class="btn" rel="nofollow noopener">{{ languages[page.lang].texts.tryBonus }}</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endif %}
    {%- endfor -%}
</div>
