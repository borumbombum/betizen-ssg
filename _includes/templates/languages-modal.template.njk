<template id="language-links-template">
    <ul class="menu grid grid-cols-2 lg:grid-cols-3 gap-2">
        
        {{ localeUrlFixDaisy(fixLang=page.lang) }}

        {% for link in page.url | locale_links %}
            <li>
                <a class="{{ languages[link.lang].menu.class }} text-base-content/80 hover:text-base-content flex items-center gap-2" href="{{ link.url }}" lang="{{ link.lang }}" hreflang="{{ link.lang }}">
                    <img src="{{ languages[link.lang].menu.flagSvg }}" class="h-6 w-6 object-cover" alt="{{ link.lang }}-flag" />
                    {{ languages[link.lang].menu.name }}
                </a>
            </li>
        {% endfor %}
    </ul>
</template>