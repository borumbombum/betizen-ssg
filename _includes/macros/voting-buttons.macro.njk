{# _includes/macros/voting-button.macro.njk #}
{% macro votingButtons(entityId, smallOnMobile = false) %}
  {% if config.votingStyle == "heart" %}
    <button
        class="btn-bz-voting heart-btn btn {% if smallOnMobile %} btn-sm {% else %} btn-md {% endif %} bg-transparent hover:bg-base-200 text-(--bz-red) gap-1"
        data-entity-id="{{ entityId }}"
        data-karma="{{ config.karmaPoints }}"
        aria-label="Vote up"
    >
        <i data-lucide="heart" class="heart-icon w-6 h-6 md:w-7 md:h-7"></i>
        <span class="heart-label hidden md:inline text-xs opacity-60 whitespace-nowrap"
              data-voted-text="{{ languages[page.lang].texts.heartVotedLabel }}"
              data-again-text="{{ languages[page.lang].texts.heartVoteAgainLabel }}">
          {{ languages[page.lang].texts.heartVoteLabel }}
        </span>
    </button>
  {% else %}
    {# Classic voting buttons #}
    <button
        class="btn-bz-voting btn {% if smallOnMobile %} btn-sm {% endif %} md:btn-md bg-transparent hover:bg-base-200 text-(--bz-green) text-neutral"
        data-entity-id="{{ entityId }}"
        data-karma="{{ config.karmaPoints }}"
    >
        👍&nbsp;+{{ config.karmaPoints }}
    </button>
    <button
        class="btn-bz-voting btn {% if smallOnMobile %} btn-sm {% endif %} md:btn-md bg-transparent text-(--bz-red) hover:bg-base-200 text-neutral"
        data-entity-id="{{ entityId }}"
        data-karma="{{ -config.karmaPoints }}"
    >
        👎&nbsp;-{{ config.karmaPoints }}
    </button>
  {% endif %}
{% endmacro %}