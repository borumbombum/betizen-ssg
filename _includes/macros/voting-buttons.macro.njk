{# _includes/macros/voting-buttons.macro.njk #}
{% macro votingButtons(entityId) %}
  {% if config.votingStyle == "heart" %}
    <button
        class="btn-bz-voting heart-btn btn btn-md border border-gray-300 dark:border-gray-600 md:btn-md bg-transparent hover:bg-base-200 text-(--bz-red) gap-2 w-full md:w-auto"
        data-entity-id="{{ entityId }}"
        data-karma="{{ config.karmaPoints }}"
        aria-label="Vote up"
    >
        <i data-lucide="heart" class="heart-icon w-6 h-6"></i>
        
        <i data-lucide="loader-circle" class="loader-icon hidden animate-spin w-6 h-6 text-(--bz-red)"></i>
        
        <span class="heart-label text-sm !text-(--bz-red) whitespace-nowrap"
            data-voted-text="{{ languages[page.lang].texts.heartVotedLabel }}"
            data-again-text="{{ languages[page.lang].texts.heartVoteAgainLabel }}">
        {{ languages[page.lang].texts.heartVoteLabel }}
        </span>
    </button>
  {% else %}
    {# Classic voting buttons remain unchanged... #}
    <button
        class="btn-bz-voting btn btn-lg md:btn-md bg-transparent hover:bg-base-200 text-(--bz-green) text-neutral"
        data-entity-id="{{ entityId }}"
        data-karma="{{ config.karmaPoints }}"
    >
        👍&nbsp;+{{ config.karmaPoints }}
    </button>
    <button
        class="btn-bz-voting btn btn-lg md:btn-md bg-transparent text-(--bz-red) hover:bg-base-200 text-neutral"
        data-entity-id="{{ entityId }}"
        data-karma="{{ -config.karmaPoints }}"
    >
        👎&nbsp;-{{ config.karmaPoints }}
    </button>
  {% endif %}
{% endmacro %}
