{# _includes/components/forex/forex-list.njk #}
{%- from "macros/reputation-button.njk" import reputationButton with context -%}
{% from "macros/voting-buttons.macro.njk" import votingButtons with context %}

<div class="flex flex-col gap-4" data-bz-listing>
    {% set counter = 0 -%}
    {% for post in postsList | sortByOrder %} 
        {% if post.data.details %}
            {% set counter = counter + 1 -%}
            {%- set logoPath -%}{{ metadata.images.forex }}{{ post.fileSlug }}-logo.webp{%- endset -%}

            <div class="flex flex-col gap-3 p-4 border border-base-300 rounded-xl shadow-sm bg-base-100 
                        md:grid md:grid-cols-[3rem_6rem_1fr_12rem_16rem] md:items-center md:gap-4 md:p-6 md:rounded-none md:border-b md:border-x-0 md:border-t-0 md:shadow-none">
                
                {# Column 1: Rank Count #}
                <div class="font-bold text-base-content/60 md:text-left">
                    #{{ counter }}
                </div>

                {# Column 2 & 3: Logo & Brand Details #}
                <a href="{{ post.url }}" class="flex items-center gap-3 md:contents">
                    {# Logo #}
                    <img
                        width="80"
                        src="{{ logoPath }}"
                        class="rounded-full w-[50px] h-[50px] md:w-[80px] md:h-[80px]"
                        alt="{{ post.data.slugOverride | slugify }}" />
                    
                    {# Title + Karma (Strictly side-by-side) #}
                    <div class="flex flex-row items-center gap-2 min-w-0 flex-wrap md:prose-lg">
                        <span class="text-base-content text-sm leading-tight font-medium md:text-xl">{{ post.data.title }}</span>
                        <div class="badge badge-soft badge-primary badge-md shrink-0 md:badge-lg"
                             data-bz-entity-id="{{ post.fileSlug }}" hidden>
                            <span data-bz-karma-value></span>
                            <span data-bz-vote-count></span>
                        </div>
                    </div>
                </a>

                {# Column 4: Voting / Score #}
                <div class="flex justify-center w-full md:justify-start md:w-auto">
                    {{ votingButtons(post.fileSlug) }}
                </div>

                {# Column 5: Actions (Reputation + Visit) #}
                <div class="flex flex-row justify-center gap-2 items-center md:justify-end">
                    {% if not post.data.blacklisted %}
                        {{ reputationButton(
                            post.data.reputation.code, 
                            post.data.reputation.text, 
                            logoPath, 
                            post.data.title, 
                            post.data.gradient, 
                            post.data.bonus.link, 
                            false, 
                            "btn-scale", 
                            false, 
                            post.url) 
                        }}
                    {% endif %}

                    {% if post.data.blacklisted %}
                        <a href="{{ post.url }}" class="btn btn-error btn-soft btn-sm md:btn-md flex-1 md:flex-initial">
                            <i data-lucide="zoom-in" class="w-4 h-4"></i>
                            <span>{{ languages[page.lang].texts.orderBlacklisted }}</span>
                        </a>
                    {% else %}
                        <div class="tooltip flex-1 md:flex-initial" data-tip="{{ languages[page.lang].texts.earn }} +{{ config.karmaPoints }} {{ languages[page.lang].texts.points }}">
                            <button
                                data-earnurl="{{ post.data.bonus.link }}"
                                class="btn-primary/20 btn btn-sm md:btn-md w-full md:w-auto"
                                >
                                <i data-lucide="external-link" strokeWidth={1} class="h-4"></i>
                                {{ languages[page.lang].texts.visit }}
                            </button>
                        </div>
                    {% endif %}
                </div>

            </div>
        {% endif %} 
    {% endfor %}
</div>