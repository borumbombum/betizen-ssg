<!-- {{ tags }} -->

{% if tags and (tags.includes("casinos") or tags.includes("forex") or tags.includes("binaries")) %}
    {%- set categoryMap = {
        "casinos": ["Online Casinos", "Casino Games", "Gambling Industry", "Slots"],
        "forex": ["Forex Brokers", "Currency Trading", "CFD Trading"],
        "binaries": ["Binary Options", "Options Trading", "Financial Trading"]
    } -%}
    {%- set imageFolder = { "casinos": metadata.images.casinos, "forex": metadata.images.forex, "binaries": metadata.images.binaries } -%}

    {%- for tagKey, knowsAboutList in categoryMap -%}
        {%- if tags.includes(tagKey) -%}
            {%- set logoPath -%}{{ imageFolder[tagKey] }}{{ page.fileSlug }}-logo.webp{%- endset -%}
            <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Article",
                "headline": {{ pageTitle | dump | safe }},
                "description": {{ description | dump | safe }},
                "url": {{ page.url | htmlBaseUrl(metadata.url) | dump | safe }},
                "image": {{ logoPath | htmlBaseUrl(metadata.url) | dump | safe }},
                "about": {
                    "@type": "Organization",
                    "name": {{ title | dump | safe }},
                    "logo": {{ logoPath | htmlBaseUrl(metadata.url) | dump | safe }}
                },
                "author": {
                    "@type": "Organization",
                    "name": "Betizen",
                    "url": {{ metadata.url | dump | safe }},
                    "knowsAbout": {{ knowsAboutList | dump | safe }}
                },
                "publisher": {
                    "@type": "Organization",
                    "name": "Betizen",
                    "url": {{ metadata.url | dump | safe }},
                    "logo": {
                        "@type": "ImageObject",
                        "url": {{ '/assets/favs/apple-touch-icon.png' | htmlBaseUrl(metadata.url) | dump | safe }}
                    }
                }
            }
            </script>
        {%- endif -%}
    {%- endfor -%}
{% endif %}

{% if tags and tags.includes("games") %}
    {%- set logoPath -%}{{ metadata.images.games }}{{ page.fileSlug }}-logo.webp{%- endset -%}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Game",
        "name": {{ title | dump | safe }},
        "url": {{ page.url | htmlBaseUrl(metadata.url) | dump | safe }},
        "image": {{ logoPath | htmlBaseUrl(metadata.url) | dump | safe }},
        "description": {{ description | dump | safe }},
        "genre": "slot",
        "author": {
            "@type": "Organization",
            "name": "Betizen",
            "url": {{ metadata.url | dump | safe }}
        },
        "publisher": {
            "@type": "Organization",
            "name": {{ provider.name | dump | safe }},
            "url": {{ provider.url | htmlBaseUrl(metadata.url) | dump | safe }}
        }
    }
    </script>
{% endif %}
